#!/usr/bin/env python3

import sys
import glob
from biom import load_table
from biom.util import biom_open

pattern = sys.argv[1]
out_biom = sys.argv[2]

files = sorted(glob.glob(pattern))

if len(files) == 0:
    raise SystemExit(f"No BIOM files found: {pattern}")

print(f"Found {len(files)} BIOM files")

merged = None

for i, f in enumerate(files, 1):
    print(f"[{i}/{len(files)}] Loading {f}")
    table = load_table(f)

    print(
        f"  samples={len(table.ids(axis='sample'))}, "
        f"SHs={len(table.ids(axis='observation'))}, "
        f"total={table.sum()}"
    )

    if merged is None:
        merged = table
    else:
        merged = merged.merge(table)

    print(
        f"  merged so far: samples={len(merged.ids(axis='sample'))}, "
        f"SHs={len(merged.ids(axis='observation'))}, "
        f"total={merged.sum()}"
    )

print("Writing merged BIOM table...")
with biom_open(out_biom, "w") as f:
    merged.to_hdf5(f, generated_by="merge_sh_biom_tables.py")

print(f"Done: {out_biom}")
