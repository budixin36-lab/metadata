count_col <- function(data, col, out_name) {
  if (!col %in% colnames(data)) {
    message("Skip missing column: ", col)
    return(NULL)
  }
  
  out <- data %>%
    mutate(value = trimws(as.character(.data[[col]]))) %>%
    mutate(value = ifelse(is.na(value) | value == "", "unknown", value)) %>%
    count(value, name = "number_of_samples") %>%
    arrange(desc(number_of_samples))
  
  write_csv(out, file.path(out_dir, out_name))
  out
