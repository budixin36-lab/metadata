#!/usr/bin/env python3

import sys
import csv
from biom import load_table
from biom.util import biom_open

in_biom = sys.argv[1]
out_biom = sys.argv[2]
removed_samples_file = sys.argv[3]
sample_counts_file = sys.argv[4]

table = load_table(in_biom)

sample_ids = list(table.ids(axis="sample"))
sample_sums = table.sum(axis="sample")

keep_samples = []
removed_samples = []

for sid, total in zip(sample_ids, sample_sums):
    if total > 0:
        keep_samples.append(sid)
    else:
        removed_samples.append((sid, total))

filtered = table.filter(keep_samples, axis="sample", inplace=False)

# 删除在保留样本中总丰度为 0 的 SH
obs_ids = list(filtered.ids(axis="observation"))
obs_sums = filtered.sum(axis="observation")
keep_obs = [oid for oid, total in zip(obs_ids, obs_sums) if total > 0]
filtered = filtered.filter(keep_obs, axis="observation", inplace=False)

with biom_open(out_biom, "w") as f:
    filtered.to_hdf5(f, generated_by="filter_zero_samples_biom.py")

with open(removed_samples_file, "w", newline="") as f:
    writer = csv.writer(f, delimiter="\t")
    writer.writerow(["sample_id", "SH_reads"])
    for sid, total in removed_samples:
        writer.writerow([sid, int(total)])

with open(sample_counts_file, "w", newline="") as f:
    writer = csv.writer(f, delimiter="\t")
    writer.writerow(["sample_id", "SH_reads"])
    for sid, total in zip(sample_ids, sample_sums):
        writer.writerow([sid, int(total)])

print("Original samples:", len(sample_ids))
print("Kept samples:", len(keep_samples))
print("Removed zero-SH samples:", len(removed_samples))
print("Original SHs:", len(table.ids(axis="observation")))
print("Filtered SHs:", len(filtered.ids(axis="observation")))
print("Output:", out_biom)
#运行：
