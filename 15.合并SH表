#运行下面这个脚本，生成每个样本的匹配率表：
cat > scripts/09_calculate_SH_mapping_rate.py <<'PY'
import subprocess
from pathlib import Path
import pandas as pd

qza_dir = Path("qza")
results_dir = Path("results")
results_dir.mkdir(exist_ok=True)

rows = []

# 找所有原始 derep table
derep_tables = sorted(qza_dir.glob("*_derep_table.qza"))

for derep_table in derep_tables:
    base = derep_table.name.replace("_derep_table.qza", "")
    sh_table = qza_dir / f"{base}_SH_table.qza"

    if not sh_table.exists():
        print(f"[SKIP] no SH table for {base}")
        continue

    tmp_total = results_dir / f"tmp_total_{base}"
    tmp_sh = results_dir / f"tmp_sh_{base}"

    tmp_total.mkdir(exist_ok=True)
    tmp_sh.mkdir(exist_ok=True)

    subprocess.run(
        ["qiime", "tools", "export",
         "--input-path", str(derep_table),
         "--output-path", str(tmp_total)],
        check=True,
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    )

    subprocess.run(
        ["qiime", "tools", "export",
         "--input-path", str(sh_table),
         "--output-path", str(tmp_sh)],
        check=True,
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    )

    total_biom = tmp_total / "feature-table.biom"
    sh_biom = tmp_sh / "feature-table.biom"

    total_tsv = tmp_total / "table.tsv"
    sh_tsv = tmp_sh / "table.tsv"

    subprocess.run(
        ["biom", "convert", "-i", str(total_biom), "-o", str(total_tsv), "--to-tsv"],
        check=True,
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    )

    subprocess.run(
        ["biom", "convert", "-i", str(sh_biom), "-o", str(sh_tsv), "--to-tsv"],
        check=True,
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    )

    def read_biom_tsv(path):
        return pd.read_csv(path, sep="\t", comment="#", index_col=0)

    total_df = read_biom_tsv(total_tsv)
    sh_df = read_biom_tsv(sh_tsv)

    total_counts = total_df.sum(axis=0)
    matched_counts = sh_df.sum(axis=0)

    for sample in total_counts.index:
        total = int(total_counts.get(sample, 0))
        matched = int(matched_counts.get(sample, 0))
        rows.append({
            "group": base,
            "sampleid": sample,
            "total_derep_reads": total,
            "matched_to_UNITE_SH": matched,
            "unmatched_reads": total - matched,
            "mapping_rate": matched / total if total > 0 else 0,
        })

    # 清理临时导出
    subprocess.run(["rm", "-rf", str(tmp_total), str(tmp_sh)], check=True)

out = results_dir / "SH_mapping_rate_by_sample.tsv"
pd.DataFrame(rows).to_csv(out, sep="\t", index=False)
print(f"Wrote {out}")
print(f"Samples: {len(rows)}")
PY
