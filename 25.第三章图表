detect_sample_col <- function(df) {
  possible_sample_cols <- c("sample_id", "SampleID", "sampleid", "sample_name", "id", "#SampleID")
  sample_col <- possible_sample_cols[possible_sample_cols %in% colnames(df)][1]
  if (is.na(sample_col)) stop("没有找到样本ID列，请检查metadata。")
  return(sample_col)
}

clean_taxon_name <- function(x) {
  x <- as.character(x)
  x[is.na(x)] <- "Unclassified"
  x <- trimws(x)
  x[x == ""] <- "Unclassified"
  x <- gsub("^p__", "", x)
  x <- gsub("^g__", "", x)
  x <- gsub("^p_", "", x)
  x <- gsub("^g_", "", x)
  x <- gsub("_", " ", x)
  x[x %in% c("unidentified", "uncultured", "Incertae sedis", "NA", "nan")] <- "Unclassified"
  x
}

extract_rank_from_taxonomy <- function(taxonomy, rank_prefix = "p") {
  # 例如 rank_prefix = "p" 提取 p__Basidiomycota
  pattern <- paste0(rank_prefix, "__[^;|]+")
  x <- stringr::str_extract(taxonomy, pattern)
  x <- gsub(paste0("^", rank_prefix, "__"), "", x)
  x <- clean_taxon_name(x)
  return(x)
}

make_color_vector <- function(n) {
  hues <- seq(15, 375, length = n + 1)
  hcl(h = hues, l = 65, c = 100)[1:n]
}

