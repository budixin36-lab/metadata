calc_group_mean <- function(abund_mat, meta_df, group_col = "host_family", group_levels = NULL) {
  if (is.null(group_levels)) group_levels <- unique(meta_df[[group_col]])
  out <- sapply(group_levels, function(g) {
    samp <- meta_df$sample_id[meta_df[[group_col]] == g]
    if (length(samp) == 1) {
      abund_mat[, samp]
    } else {
      rowMeans(abund_mat[, samp, drop = FALSE])
    }
  })
  out <- as.matrix(out)
  colnames(out) <- group_levels
  return(out)
}

