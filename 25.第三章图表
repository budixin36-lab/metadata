# -----------------------------
# 2. Read metadata
# -----------------------------
meta <- read.csv(
  metadata_file,
  stringsAsFactors = FALSE,
  check.names = FALSE
)

# 检查宿主科列
if (!"host_family" %in% colnames(meta)) {
  stop("metadata 中没有 host_family 列，请检查列名。")
}

# 猜测样本 ID 列
possible_sample_cols <- c("sample_id", "SampleID", "sampleid", "sample_name", "id", "#SampleID")
sample_col <- possible_sample_cols[possible_sample_cols %in% colnames(meta)][1]

if (is.na(sample_col)) {
  stop("没有找到样本 ID 列。请检查 metadata 中样本 ID 列名。")
}

meta <- meta %>%
  mutate(
    sample_id = .data[[sample_col]],
    host_family = trimws(as.character(host_family))
  ) %>%
  filter(
    !is.na(sample_id),
    sample_id != "",
    !is.na(host_family),
    host_family != "",
    host_family != "NA",
    host_family != "missing",
    host_family != "not_recorded",
    host_family != "not reported"
  )

cat("Metadata samples after filtering host_family:", nrow(meta), "\n")
cat("Host families:\n")
print(sort(table(meta$host_family), decreasing = TRUE))

# -----------------------------
# 3. Read BIOM table
# -----------------------------
biom <- read_biom(biom_file)
mat <- as(biom_data(biom), "matrix")

# biomformat 读出来通常是 feature x sample
cat("Original BIOM matrix dimension:", nrow(mat), "features x", ncol(mat), "samples\n")

# 对齐 metadata 和 biom 样本
common_samples <- intersect(colnames(mat), meta$sample_id)

if (length(common_samples) == 0) {
  stop("BIOM 样本名和 metadata 样本名没有交集，请检查 sample_id 列。")
}

mat <- mat[, common_samples, drop = FALSE]
meta2 <- meta %>%
  filter(sample_id %in% common_samples) %>%
  distinct(sample_id, .keep_all = TRUE)

# 按 biom 样本顺序排列 metadata
meta2 <- meta2[match(colnames(mat), meta2$sample_id), ]

cat("Matched samples:", ncol(mat), "\n")
cat("Matched host families:\n")
print(sort(table(meta2$host_family), decreasing = TRUE))

# -----------------------------
# 4. Build SH presence/absence by host family
# -----------------------------
host_families <- sort(unique(meta2$host_family))

# 每个 SH 在每个 host_family 中是否出现过
presence_list <- list()

for (hf in host_families) {
  samples_hf <- meta2$sample_id[meta2$host_family == hf]
  sub_mat <- mat[, samples_hf, drop = FALSE]
  present_sh <- rownames(sub_mat)[rowSums(sub_mat > 0) > 0]
  presence_list[[hf]] <- present_sh
}

# 保存每个宿主科检测到的 SH 数
set_size_df <- tibble(
  host_family = names(presence_list),
  SH_number = lengths(presence_list)
) %>%
  arrange(desc(SH_number))

write.csv(
  set_size_df,
  file.path(out_dir, "host_family_SH_set_size.csv"),
  row.names = FALSE
)

# 生成 UpSetR 输入矩阵
all_sh <- sort(unique(unlist(presence_list)))

upset_df <- tibble(SH_ID = all_sh)

for (hf in host_families) {
  upset_df[[hf]] <- as.integer(upset_df$SH_ID %in% presence_list[[hf]])
}

write.csv(
  upset_df,
  file.path(out_dir, "host_family_SH_presence_absence_matrix.csv"),
  row.names = FALSE
)

