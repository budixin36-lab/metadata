tax_raw <- read.delim(
  taxonomy_file,
  stringsAsFactors = FALSE,
  check.names = FALSE
)

cat("Taxonomy columns:\n")
print(colnames(tax_raw))

# 自动识别 SH ID 列
possible_id_cols <- c("SH", "SH_ID", "Feature.ID", "FeatureID", "feature_id", "ID", "id", "#OTUID", "OTUID")
id_col <- possible_id_cols[possible_id_cols %in% colnames(tax_raw)][1]

if (is.na(id_col)) {
  id_col <- colnames(tax_raw)[1]
  message("未识别标准 SH ID 列，默认使用 taxonomy 第一列：", id_col)
}

# 自动识别 taxonomy 列
possible_tax_cols <- c("taxonomy", "Taxon", "taxon", "Taxonomy", "UNITE_taxonomy")
tax_col <- possible_tax_cols[possible_tax_cols %in% colnames(tax_raw)][1]

if (is.na(tax_col)) {
  # 如果没有单独 taxonomy 列，就尝试是否已有 phylum 列
  if ("phylum" %in% colnames(tax_raw)) {
    tax_df <- tax_raw %>%
      transmute(
        SH_ID = .data[[id_col]],
        phylum = as.character(phylum)
      )
  } else {
    stop("taxonomy 文件中没有识别到 taxonomy 或 phylum 列，请检查 SH_taxonomy_matched.tsv。")
  }
} else {
  tax_df <- tax_raw %>%
    transmute(
      SH_ID = .data[[id_col]],
      taxonomy = as.character(.data[[tax_col]])
    ) %>%
    mutate(
      phylum = str_extract(taxonomy, "p__[^;|]+"),
      phylum = str_replace(phylum, "^p__", ""),
      phylum = ifelse(is.na(phylum) | phylum == "" | phylum == "unidentified", "Unclassified", phylum)
    )
}

tax_df <- tax_df %>%
  mutate(
    phylum = str_replace_all(phylum, "^p_", ""),
    phylum = str_replace_all(phylum, "^p__", ""),
    phylum = str_replace_all(phylum, "_", " "),
    phylum = ifelse(is.na(phylum) | phylum == "", "Unclassified", phylum)
  ) %>%
  distinct(SH_ID, .keep_all = TRUE)

# -----------------------------
# 8. Phylum composition of shared SHs
# -----------------------------
if (length(shared_sh) == 0) {
  stop("所有宿主科共有 SH 数为 0，无法绘制共有 SH 门水平组成图。")
}

shared_mat <- mat[shared_sh, , drop = FALSE]

# 使用共有 SH 在所有样本中的总 reads 计算门水平相对丰度
shared_abund <- tibble(
  SH_ID = rownames(shared_mat),
  total_reads = rowSums(shared_mat)
) %>%
  left_join(tax_df, by = "SH_ID") %>%
  mutate(
    phylum = ifelse(is.na(phylum) | phylum == "", "Unclassified", phylum)
  )

shared_phylum <- shared_abund %>%
  group_by(phylum) %>%
  summarise(
    SH_number = n(),
    total_reads = sum(total_reads),
    .groups = "drop"
  ) %>%
  mutate(
    relative_abundance = total_reads / sum(total_reads) * 100
  ) %>%
  arrange(desc(relative_abundance))

# 低丰度门合并为 Others，阈值可调整
threshold <- 1

shared_phylum_plot <- shared_phylum %>%
  mutate(
    phylum_plot = ifelse(relative_abundance < threshold, "Others", phylum)
  ) %>%
  group_by(phylum_plot) %>%
  summarise(
    SH_number = sum(SH_number),
    total_reads = sum(total_reads),
    relative_abundance = sum(relative_abundance),
    .groups = "drop"
  ) %>%
  arrange(desc(relative_abundance)) %>%
  mutate(
    phylum_plot = factor(phylum_plot, levels = phylum_plot),
    label = paste0(phylum_plot, "\n", sprintf("%.1f%%", relative_abundance))
  )

write.csv(
  shared_phylum,
  file.path(out_dir, "shared_SHs_all_host_families_phylum_composition_full.csv"),
