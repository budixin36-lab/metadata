FOUND_FILE="${OUT_DIR}/enaquery_found.txt"
NOT_FOUND_FILE="${OUT_DIR}/enaquery_not_found.txt"
NO_FASTQ_FILE="${OUT_DIR}/enaquery_no_fastq.txt"
DETAIL_TSV="${OUT_DIR}/enaquery_details.tsv"

: > "$FOUND_FILE"
: > "$NOT_FOUND_FILE"
: > "$NO_FASTQ_FILE"

echo -e "run_accession\tstudy_accession\tfastq_ftp\tfastq_aspera\tfastq_md5" > "$DETAIL_TSV"

fetch_ena_info() {
  local run="$1"
  curl -fsSL "https://www.ebi.ac.uk/ena/portal/api/filereport?accession=${run}&result=read_run&fields=run_accession,study_accession,fastq_ftp,fastq_aspera,fastq_md5&format=tsv" 2>/dev/null
}

while IFS= read -r run || [ -n "$run" ]; do
  run="$(echo "$run" | xargs)"
  [ -z "$run" ] && continue

  tsv="$(fetch_ena_info "$run" || true)"
  line="$(echo "$tsv" | tail -n +2 | head -n 1)"

  if [ -z "$line" ]; then
    echo "$run" >> "$NOT_FOUND_FILE"
    continue
  fi

  IFS=$'\t' read -r run_accession study_accession fastq_ftp fastq_aspera fastq_md5 <<< "$line"

  if [ -z "${fastq_ftp:-}" ] && [ -z "${fastq_aspera:-}" ]; then
    echo "$run" >> "$NO_FASTQ_FILE"
    echo -e "${run_accession}\t${study_accession}\t${fastq_ftp}\t${fastq_aspera}\t${fastq_md5}" >> "$DETAIL_TSV"
    continue
  fi

  echo "$run" >> "$FOUND_FILE"
  echo -e "${run_accession}\t${study_accession}\t${fastq_ftp}\t${fastq_aspera}\t${fastq_md5}" >> "$DETAIL_TSV"

done < "$RUN_LIST"

sort -u "$FOUND_FILE" -o "$FOUND_FILE"
sort -u "$NOT_FOUND_FILE" -o "$NOT_FOUND_FILE"
sort -u "$NO_FASTQ_FILE" -o "$NO_FASTQ_FILE"

