#!/usr/bin/env bash
set -euo pipefail

LIST_DIR="/mnt/d/SRR_Acc_List"
RAW_DIR="/mnt/d/ITS/rawfastq"
OUT_DIR="/mnt/d/ITS/final_check"

mkdir -p "$OUT_DIR"

MISSING_FILE="${OUT_DIR}/missing_runs.txt"
PRESENT_FILE="${OUT_DIR}/present_runs.txt"
SUMMARY_FILE="${OUT_DIR}/summary.tsv"

: > "$MISSING_FILE"
: > "$PRESENT_FILE"
echo -e "project\ttotal_runs\truns_present\truns_missing" > "$SUMMARY_FILE"

shopt -s nullglob

for listfile in "${LIST_DIR}"/*_SRR_Acc_List.txt; do
  base="$(basename "$listfile")"
  project="${base%_SRR_Acc_List.txt}"
  project_dir="${RAW_DIR}/${project}"

  total_runs=0
  runs_present=0
  runs_missing=0

  while IFS= read -r run || [ -n "$run" ]; do
    run="$(echo "$run" | tr -d '\r' | xargs)"
    [ -z "$run" ] && continue

    total_runs=$((total_runs + 1))

    matches=("${project_dir}/${run}.fastq.gz" "${project_dir}/${run}"_*.fastq.gz)

    found=0
    for f in "${matches[@]}"; do
      if [ -f "$f" ]; then
        found=1
        break
      fi
    done

    if [ $found -eq 1 ]; then
      runs_present=$((runs_present + 1))
      echo -e "${project}\t${run}" >> "$PRESENT_FILE"
    else
      runs_missing=$((runs_missing + 1))
      echo -e "${project}\t${run}" >> "$MISSING_FILE"
    fi
  done < "$listfile"

  echo -e "${project}\t${total_runs}\t${runs_present}\t${runs_missing}" >> "$SUMMARY_FILE"
done

echo "检查完成："
ls -lh "$OUT_DIR"
