required_cols = ["sampleid", "BioProject", "single_paired", "amplified_region"]
missing_cols = [c for c in required_cols if c not in df.columns]
if missing_cols:
    raise SystemExit(
        f"Missing columns in metadata: {missing_cols}\n"
        f"Available columns: {list(df.columns)}"
    )

df["sampleid"] = df["sampleid"].astype(str)
df["BioProject"] = df["BioProject"].astype(str)
df["single_paired"] = df["single_paired"].astype(str).str.lower()
df["amplified_region"] = df["amplified_region"].astype(str).str.upper()

fastqs = []
for pattern in ["*.fastq.gz", "*.fq.gz", "*.fastq", "*.fq"]:
    fastqs.extend(raw_dir.rglob(pattern))
fastqs = [str(x) for x in fastqs]

print(f"Found FASTQ files: {len(fastqs)}")


def basename_no_ext(path):
    name = os.path.basename(path)
    name = re.sub(
        r"\.fastq\.gz$|\.fq\.gz$|\.fastq$|\.fq$",
        "",
        name,
        flags=re.I,
    )
    return name


def is_exact_sample_fastq(sampleid, filepath):
    """
    文件名必须以 sampleid 开头，并且 sampleid 后面只能接 read 标记。
    这样可以避免 XJ19_1 误匹配到 XJ19_10。
    """
    base = basename_no_ext(filepath)

    if not base.startswith(sampleid):
        return False

    suffix = base[len(sampleid):]

    # single-end 文件名刚好等于 sampleid
    if suffix == "":
        return True

    # paired-end 常见后缀:
    # .1, .2, _1, _2, -1, -2
    # .R1, .R2, _R1, _R2
    # _R1_001, _R2_001
    # .forward, .reverse
    pattern = r"^([._-](R?[12])([._-].*)?|[._-](forward|reverse|fwd|rev)([._-].*)?)$"
    return re.match(pattern, suffix, re.I) is not None


def read_direction_from_suffix(sampleid, filepath):
    """
    只看 sampleid 后面的后缀来判断 R1/R2。
    例如：
    HJ19_2.1.fastq.gz -> sampleid=HJ19_2, suffix=.1 -> R1
    HJ19_2.2.fastq.gz -> sampleid=HJ19_2, suffix=.2 -> R2
    """
    base = basename_no_ext(filepath)

    if not base.startswith(sampleid):
        return None

    suffix = base[len(sampleid):]

    if re.search(r"(^|[._-])R?1($|[._-])", suffix, re.I):
        return "R1"
    if re.search(r"(^|[._-])R?2($|[._-])", suffix, re.I):
        return "R2"
    if re.search(r"(forward|fwd)", suffix, re.I):
        return "R1"
    if re.search(r"(reverse|rev)", suffix, re.I):
        return "R2"

    return None


def find_fastqs_for_sample(sampleid, bioproject):
    candidates = [f for f in fastqs if f"/{bioproject}/" in f]
    if not candidates:
        candidates = fastqs

    hits = [f for f in candidates if is_exact_sample_fastq(sampleid, f)]

    r1_hits = []
    r2_hits = []
    unknown_hits = []

    for f in hits:
        direction = read_direction_from_suffix(sampleid, f)
        if direction == "R1":
            r1_hits.append(f)
        elif direction == "R2":
            r2_hits.append(f)
        else:
            unknown_hits.append(f)

    return sorted(hits), sorted(r1_hits), sorted(r2_hits), sorted(unknown_hits)


paired_records = {r: [] for r in ["ITS1", "ITS2", "ALL"]}
single_records = {r: [] for r in ["ITS1", "ITS2", "ALL"]}
missing = []
duplicate_or_suspicious = []

for _, row in df.iterrows():
    sid = row["sampleid"]
    bp = row["BioProject"]
    layout = row["single_paired"]
    region = row["amplified_region"]

    if region not in ["ITS1", "ITS2", "ALL"]:
        missing.append({**row.to_dict(), "reason": f"unknown region {region}"})
        continue

    hits, r1_hits, r2_hits, unknown_hits = find_fastqs_for_sample(sid, bp)

    if layout == "paired":
        if len(r1_hits) >= 1 and len(r2_hits) >= 1:
            r1 = r1_hits[0]
            r2 = r2_hits[0]

            if r1 == r2:
                missing.append({**row.to_dict(), "reason": f"R1 and R2 identical: {r1}"})
                continue

            if len(r1_hits) > 1 or len(r2_hits) > 1:
                duplicate_or_suspicious.append({
                    "sampleid": sid,
                    "BioProject": bp,
                    "region": region,
                    "r1_hits": ";".join(r1_hits),
                    "r2_hits": ";".join(r2_hits),
                    "unknown_hits": ";".join(unknown_hits),
                })

            paired_records[region].append({
                "sample-id": sid,
                "forward-absolute-filepath": r1,
                "reverse-absolute-filepath": r2,
            })

        else:
            missing.append({
                **row.to_dict(),
                "reason": (
                    f"paired fastq not found correctly; "
                    f"hits={len(hits)}; R1={len(r1_hits)}; "
                    f"R2={len(r2_hits)}; unknown={len(unknown_hits)}"
                ),
            })

    elif layout == "single":
        if len(hits) >= 1:
            if len(hits) > 1:
                duplicate_or_suspicious.append({
                    "sampleid": sid,
                    "BioProject": bp,
                    "region": region,
                    "r1_hits": "",
                    "r2_hits": "",
                    "unknown_hits": ";".join(hits),
                })

            single_records[region].append({
                "sample-id": sid,
                "absolute-filepath": sorted(hits)[0],
                "direction": "forward",
            })

        else:
            missing.append({**row.to_dict(), "reason": "single fastq not found"})

    else:
        missing.append({**row.to_dict(), "reason": f"unknown layout {layout}"})


for region, records in paired_records.items():
    out = out_dir / f"manifest_paired_{region}.tsv"
    pd.DataFrame(records).to_csv(out, sep="\t", index=False)

for region, records in single_records.items():
