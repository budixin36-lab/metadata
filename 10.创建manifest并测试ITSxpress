        missing.append({**row.to_dict(), "reason": f"unknown region {region}"})
        continue

    hits, r1_hits, r2_hits = find_fastqs_for_sample(sid, bp)

    if layout == "paired":
        if len(r1_hits) >= 1 and len(r2_hits) >= 1:
            paired_records[region].append({
                "sample-id": sid,
                "forward-absolute-filepath": r1_hits[0],
                "reverse-absolute-filepath": r2_hits[0]
            })
        else:
            missing.append({**row.to_dict(), "reason": f"paired fastq not found; hits={len(hits)}"})
    elif layout == "single":
        if len(hits) >= 1:
            single_records[region].append({
                "sample-id": sid,
                "absolute-filepath": sorted(hits)[0],
                "direction": "forward"
            })
        else:
            missing.append({**row.to_dict(), "reason": "single fastq not found"})
    else:
