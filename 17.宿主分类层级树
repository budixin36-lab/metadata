  "Wild" = "#FDB863",
  "Other" = "#BDBDBD"
)

country_levels <- sort(unique(species_summary$main_country))
country_cols <- setNames(
  colorRampPalette(brewer.pal(12, "Paired"))(length(country_levels)),
  country_levels
)

# ---------- 写 iTOL colorstrip ----------
write_colorstrip <- function(filename, dataset_label, legend_title, id_col, group_col, colors) {
  f <- file.path(outdir, filename)
  cat("DATASET_COLORSTRIP\n", file = f)
  cat("SEPARATOR TAB\n", file = f, append = TRUE)
  cat(paste0("DATASET_LABEL\t", dataset_label, "\n"), file = f, append = TRUE)
  cat("COLOR\t#000000\n", file = f, append = TRUE)
  cat(paste0("LEGEND_TITLE\t", legend_title, "\n"), file = f, append = TRUE)
  cat(paste0("LEGEND_SHAPES\t", paste(rep(1, length(colors)), collapse = "\t"), "\n"), file = f, append = TRUE)
  cat(paste0("LEGEND_COLORS\t", paste(unname(colors), collapse = "\t"), "\n"), file = f, append = TRUE)
  cat(paste0("LEGEND_LABELS\t", paste(names(colors), collapse = "\t"), "\n"), file = f, append = TRUE)
  cat("DATA\n", file = f, append = TRUE)

  dat <- data.frame(
    id = id_col,
    color = unname(colors[group_col]),
    label = group_col,
    stringsAsFactors = FALSE
  )

  write.table(
    dat,
    f,
    sep = "\t",
    quote = FALSE,
    row.names = FALSE,
    col.names = FALSE,
    append = TRUE
  )
}

write_colorstrip(
  filename = "itol_host_family_colorstrip.txt",
  dataset_label = "Host family",
  legend_title = "Host family",
  id_col = species_summary$tip_id,
