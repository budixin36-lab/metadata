#你在 WSL 里运行下面脚本后，会生成这些文件：
#results/itol_host_tree/host_taxonomic_tree.nwk
#results/itol_host_tree/itol_labels.txt
#results/itol_host_tree/itol_host_family_colorstrip.txt
#results/itol_host_tree/itol_samples_simplebar.txt
#results/itol_host_tree/itol_status_colorstrip.txt
#results/itol_host_tree/itol_country_colorstrip.txt
#results/itol_host_tree/host_species_summary_for_iTOL.tsv
#然后把这些上传到 iTOL，就能在网页里手动调图。
#1. 生成 iTOL 文件
#在 WSL 里运行：
cd /mnt/d/ITS_SH_pipeline

cat > scripts/10_make_itol_host_tree_files.R <<'RSCRIPT'
library(dplyr)
library(tidyr)
library(stringr)
library(RColorBrewer)

input <- "metadata/metadata_valid_SH_table_matched.tsv"
outdir <- "results/itol_host_tree"
dir.create(outdir, showWarnings = FALSE, recursive = TRUE)

meta <- read.delim(input, sep = "\t", check.names = FALSE, stringsAsFactors = FALSE)

if ("sample-id" %in% names(meta) && !"sampleid" %in% names(meta)) {
  names(meta)[names(meta) == "sample-id"] <- "sampleid"
}

needed <- c("sampleid", "host_order", "host_family", "host_genus",
            "host_species", "status", "country")

missing_cols <- setdiff(needed, names(meta))
if (length(missing_cols) > 0) {
  stop("Missing columns: ", paste(missing_cols, collapse = ", "))
}

empty_values <- c(
  "", "NA", "N/A", "na", "n/a",
  "missing", "Missing", "MISSING",
  "not recorded", "not_recorded",
  "not reported", "not_reported",
  "unknown", "Unknown", "UNKNOWN"
)

clean_text <- function(x) {
  x <- trimws(as.character(x))
  x[x %in% empty_values | is.na(x)] <- "Unknown"
  x
}

safe_id <- function(x) {
  x <- gsub(" x ", "_x_", x)
  x <- gsub("[^A-Za-z0-9]+", "_", x)
  x <- gsub("^_+|_+$", "", x)
  x
}

meta2 <- meta %>%
  mutate(
    host_order = clean_text(host_order),
    host_family = clean_text(host_family),
    host_genus = clean_text(host_genus),
    host_species = clean_text(host_species),
    status = clean_text(status),
    country = clean_text(country)
  ) %>%
  filter(
    host_order != "Unknown",
    host_family != "Unknown",
    host_genus != "Unknown",
    host_species != "Unknown"
  ) %>%
  mutate(
    status = case_when(
      str_detect(str_to_lower(status), "domestic|domesticated|demestic|demesticated") ~ "Domesticated",
      str_detect(str_to_lower(status), "captive") ~ "Captive",
      str_detect(str_to_lower(status), "wild") ~ "Wild",
      TRUE ~ "Other"
    ),
    country = ifelse(country == "Unknown", "Other", country)
  )

species_summary <- meta2 %>%
  group_by(host_order, host_family, host_genus, host_species) %>%
  summarise(samples = n(), .groups = "drop") %>%
  arrange(host_order, host_family, host_genus, host_species) %>%
  mutate(
    tip_id = safe_id(host_species)
  )

# 防止不同物种清洗后 ID 重复
if (any(duplicated(species_summary$tip_id))) {
  species_summary <- species_summary %>%
    group_by(tip_id) %>%
    mutate(tip_id = ifelse(n() > 1, paste0(tip_id, "_", row_number()), tip_id)) %>%
    ungroup()
}

# 每个物种主状态、主国家
status_main <- meta2 %>%
  group_by(host_species, status) %>%
  summarise(n = n(), .groups = "drop") %>%
  group_by(host_species) %>%
  slice_max(n, n = 1, with_ties = FALSE) %>%
  ungroup() %>%
  select(host_species, main_status = status)

country_main <- meta2 %>%
  group_by(host_species, country) %>%
  summarise(n = n(), .groups = "drop") %>%
  group_by(host_species) %>%
  slice_max(n, n = 1, with_ties = FALSE) %>%
  ungroup() %>%
  select(host_species, main_country = country)

species_summary <- species_summary %>%
  left_join(status_main, by = "host_species") %>%
  left_join(country_main, by = "host_species")

write.table(
  species_summary,
  file.path(outdir, "host_species_summary_for_iTOL.tsv"),
  sep = "\t",
  quote = FALSE,
  row.names = FALSE
)

# ---------- 生成 Newick 树 ----------
make_species_newick <- function(df) {
  paste0(df$tip_id, ":1", collapse = ",")
}

make_genus_newick <- function(df) {
  genus_parts <- df %>%
    group_by(host_genus) %>%
    group_split()

  paste(
    sapply(genus_parts, function(gdf) {
      genus <- unique(gdf$host_genus)
      paste0("(", make_species_newick(gdf), ")", safe_id(genus), ":1")
    }),
    collapse = ","
  )
}

make_family_newick <- function(df) {
  family_parts <- df %>%
    group_by(host_family) %>%
    group_split()

  paste(
    sapply(family_parts, function(fdf) {
      fam <- unique(fdf$host_family)
      n <- sum(fdf$samples)
      paste0("(", make_genus_newick(fdf), ")", safe_id(paste0(fam, "_n", n)), ":1")
    }),
    collapse = ","
  )
}

make_order_newick <- function(df) {
  order_parts <- df %>%
    group_by(host_order) %>%
    group_split()

  paste(
    sapply(order_parts, function(odf) {
      ord <- unique(odf$host_order)
      n <- sum(odf$samples)
      paste0("(", make_family_newick(odf), ")", safe_id(paste0(ord, "_n", n)), ":1")
    }),
    collapse = ","
  )
}

newick <- paste0("(", make_order_newick(species_summary), ")Root;")
writeLines(newick, file.path(outdir, "host_taxonomic_tree.nwk"))

# ---------- iTOL labels：让 tip 显示原始物种名 ----------
labels_file <- file.path(outdir, "itol_labels.txt")
cat("LABELS\n", file = labels_file)
cat("SEPARATOR TAB\n", file = labels_file, append = TRUE)
cat("DATA\n", file = labels_file, append = TRUE)
write.table(
