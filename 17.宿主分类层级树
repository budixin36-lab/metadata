  }
}

country_pie_file <- file.path(outdir, "itol_country_piechart_v2.txt")
cat("DATASET_PIECHART\n", file = country_pie_file)
cat("SEPARATOR TAB\n", file = country_pie_file, append = TRUE)
cat("DATASET_LABEL\tCountry\n", file = country_pie_file, append = TRUE)
cat("COLOR\t#000000\n", file = country_pie_file, append = TRUE)
cat(paste0("FIELD_COLORS\t", paste(country_cols[country_levels], collapse = "\t"), "\n"), file = country_pie_file, append = TRUE)
cat(paste0("FIELD_LABELS\t", paste(country_levels, collapse = "\t"), "\n"), file = country_pie_file, append = TRUE)
cat("MARGIN\t10\n", file = country_pie_file, append = TRUE)
cat("HEIGHT_FACTOR\t0.9\n", file = country_pie_file, append = TRUE)
cat("BORDER_WIDTH\t1\n", file = country_pie_file, append = TRUE)
cat("BORDER_COLOR\t#FFFFFF\n", file = country_pie_file, append = TRUE)
cat("LEGEND_TITLE\tCountry\n", file = country_pie_file, append = TRUE)
cat(paste0("LEGEND_SHAPES\t", paste(rep(1, length(country_levels)), collapse = "\t"), "\n"), file = country_pie_file, append = TRUE)
cat(paste0("LEGEND_COLORS\t", paste(country_cols[country_levels], collapse = "\t"), "\n"), file = country_pie_file, append = TRUE)
cat(paste0("LEGEND_LABELS\t", paste(country_levels, collapse = "\t"), "\n"), file = country_pie_file, append = TRUE)
cat("DATA\n", file = country_pie_file, append = TRUE)

country_out <- country_counts %>%
  select(tip_id, all_of(country_levels)) %>%
  mutate(position = -1, radius = 10) %>%
  select(tip_id, position, radius, all_of(country_levels))

write.table(
  country_out,
  country_pie_file,
  sep = "\t",
  quote = FALSE,
  row.names = FALSE,
  col.names = FALSE,
  append = TRUE
)

