#!/usr/bin/env bash
set -euo pipefail

THREADS=4

export TMPDIR="/tmp"
export TMP="/tmp"
export TEMP="/tmp"

mkdir -p qza qzv logs

run_single () {
    region=$1
    manifest="manifests/manifest_single_${region}.tsv"

    demux="qza/single_${region}_demux.qza"
    trimmed="qza/single_${region}_itsxpress.qza"
    table="qza/single_${region}_derep_table.qza"
    repseqs="qza/single_${region}_derep_repseqs.qza"

    n=$(($(wc -l < "$manifest") - 1))
    if [[ "$n" -le 0 ]]; then
        echo "[SKIP] single $region has no samples"
        return
    fi

    echo "[IMPORT] single $region, samples=$n"
    if [[ ! -s "$demux" ]]; then
        qiime tools import \
          --type 'SampleData[SequencesWithQuality]' \
          --input-path "$manifest" \
          --output-path "$demux" \
          --input-format SingleEndFastqManifestPhred33V2 \
          > "logs/import_single_${region}.log" 2>&1
    else
        echo "[SKIP] $demux exists"
    fi

    echo "[SUMMARIZE DEMUX] single $region"
    if [[ ! -s "qzv/single_${region}_demux.qzv" ]]; then
        qiime demux summarize \
          --i-data "$demux" \
          --o-visualization "qzv/single_${region}_demux.qzv" \
          > "logs/summarize_demux_single_${region}.log" 2>&1
    fi

    echo "[ITSxpress] single $region"
    if [[ ! -s "$trimmed" ]]; then
        qiime itsxpress trim-single \
          --i-per-sample-sequences "$demux" \
          --p-region "$region" \
          --p-taxa F \
          --p-cluster-id 1.0 \
          --p-threads "$THREADS" \
          --o-trimmed "$trimmed" \
          > "logs/itsxpress_single_${region}.log" 2>&1
    else
        echo "[SKIP] $trimmed exists"
    fi

    echo "[SUMMARIZE TRIMMED] single $region"
    if [[ ! -s "qzv/single_${region}_itsxpress.qzv" ]]; then
        qiime demux summarize \
          --i-data "$trimmed" \
          --o-visualization "qzv/single_${region}_itsxpress.qzv" \
          > "logs/summarize_itsxpress_single_${region}.log" 2>&1
    fi

    echo "[DEREP] single $region"
    if [[ ! -s "$table" || ! -s "$repseqs" ]]; then
        qiime vsearch dereplicate-sequences \
          --i-sequences "$trimmed" \
          --p-min-seq-length 1 \
          --p-min-unique-size 1 \
          --o-dereplicated-table "$table" \
          --o-dereplicated-sequences "$repseqs" \
          > "logs/derep_single_${region}.log" 2>&1
    else
        echo "[SKIP] derep single $region exists"
    fi

    echo "[DONE] single $region"
}

run_single ITS2
rm -rf /tmp/qiime2*

run_single ITS1
rm -rf /tmp/qiime2*

echo "Remaining single groups finished."
#保存后运行：
chmod +x scripts/03_run_remaining_single_groups.sh
