make_genus_subtree <- function(d_genus) {
  genus_id <- unique(d_genus$genus_id)
  species_ids <- d_genus %>%
    arrange(host_species) %>%
    pull(species_id) %>%
    unique()
  paste0("(", paste(species_ids, collapse = ","), ")", genus_id)
}

make_family_subtree <- function(d_family) {
  family_id <- unique(d_family$family_id)
  genus_list <- d_family %>%
    distinct(host_genus, genus_id) %>%
    arrange(host_genus)

  genus_subtrees <- c()

  for (i in seq_len(nrow(genus_list))) {
    g <- genus_list$host_genus[i]
    d_g <- d_family %>% filter(host_genus == g)
    genus_subtrees <- c(genus_subtrees, make_genus_subtree(d_g))
  }

  paste0("(", paste(genus_subtrees, collapse = ","), ")", family_id)
}

make_order_subtree <- function(d_order) {
  order_id <- unique(d_order$order_id)
  family_list <- d_order %>%
    distinct(host_family, family_id) %>%
    arrange(host_family)

  family_subtrees <- c()

  for (i in seq_len(nrow(family_list))) {
    f <- family_list$host_family[i]
    d_f <- d_order %>% filter(host_family == f)
    family_subtrees <- c(family_subtrees, make_family_subtree(d_f))
  }

  paste0("(", paste(family_subtrees, collapse = ","), ")", order_id)
}

