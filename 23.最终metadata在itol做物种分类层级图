Rscript globalfungi_style_test/scripts/make_itol_annotations_final_SH_v4.R
#3. 在 iTOL 里先删掉旧的 annotation
#你现在左下角已经有：Taxonomic labels、Samples
#先点每个 dataset 旁边的垃圾桶，删掉旧的：Taxonomic labels、Samples、Status、Country
#然后重新上传 v4 的文件。
#4. 上传顺序
#树可以继续用你现在的 v3 tree：
#host_taxonomic_tree_final_SH_v3.nwk
#然后上传 v4 annotation：
#itol_labels_final_SH_v4.txt
#itol_internal_labels_no_genus_final_SH_v4.txt
#itol_samples_text_final_SH_v4.txt
#itol_status_pie_final_SH_v4.txt
#itol_country_pie_final_SH_v4.txt
#问题找到了：iTOL 的 DATASET_PIECHART 每一行不是 ID + 数值，而是必须是：
#ID    position    radius    value1    value2    value3 ...
#也就是说，你现在的行：
#sp_Bos_bonasus    0    0    6    0
#被 iTOL 理解成：
#ID = sp_Bos_bonasus
#position = 0
#radius = 0
#value1 = 6
#value2 = 0
#这样它只读到 2 个 value，但你有 4 个 FIELD_LABELS，所以报：
#number of fields does not match the number of field labels
#iTOL 官方模板也说明 pie chart 的每个 node 数据行需要 ID, position, radius, value1, value2, value3...。
#直接整体覆盖 v4 脚本，在 WSL 里运行：
cd /mnt/d/ITS_SH_pipeline

cat > globalfungi_style_test/scripts/make_itol_annotations_final_SH_v4.R <<'EOF'
# make_itol_annotations_final_SH_v4.R
# 修复 iTOL annotation files:
# 1. 不显示属名
# 2. 修复 DATASET_PIECHART 字段数问题
# 3. tree 使用 v3 的 safe IDs

library(readr)
library(dplyr)
library(tidyr)
library(RColorBrewer)

metadata_file <- "/mnt/d/ITS_SH_pipeline/globalfungi_style_test/metadata/metadata_valid_globalfungi_SH_nozero.csv"

out_dir <- "/mnt/d/ITS_SH_pipeline/globalfungi_style_test/results/itol_final_SH_v4"
dir.create(out_dir, recursive = TRUE, showWarnings = FALSE)

out_labels <- file.path(out_dir, "itol_labels_final_SH_v4.txt")
out_internal_labels <- file.path(out_dir, "itol_internal_labels_no_genus_final_SH_v4.txt")
out_samples_text <- file.path(out_dir, "itol_samples_text_final_SH_v4.txt")
out_status_pie <- file.path(out_dir, "itol_status_pie_final_SH_v4.txt")
out_country_pie <- file.path(out_dir, "itol_country_pie_final_SH_v4.txt")

safe_id <- function(x) {
  x <- trimws(as.character(x))
  x <- gsub("'", "", x)
  x <- gsub("\\s+", "_", x)
  x <- gsub("[,;()\\[\\]:]", "_", x)
  x <- gsub("[^A-Za-z0-9_.-]", "_", x)
  x
}

clean_value <- function(x) {
  x <- trimws(as.character(x))
  x[is.na(x) | x == "" | x %in% c("NA", "N/A", "missing", "not_recorded", "not reported")] <- "unknown"
  x
}

df <- read_csv(metadata_file, show_col_types = FALSE)

df2 <- df %>%
  mutate(
    host_order = clean_value(host_order),
    host_family = clean_value(host_family),
    host_genus = clean_value(host_genus),
    host_species = clean_value(host_species),
    status = clean_value(status),
    country = clean_value(country)
  ) %>%
  filter(
    host_order != "unknown",
    host_family != "unknown",
    host_genus != "unknown",
    host_species != "unknown"
  ) %>%
  mutate(
    species_id = paste0("sp_", safe_id(host_species)),
    genus_id = paste0("genus_", safe_id(host_genus)),
    family_id = paste0("family_", safe_id(host_family)),
    order_id = paste0("order_", safe_id(host_order))
  )

species_summary <- df2 %>%
  group_by(host_order, host_family, host_genus, host_species, species_id, genus_id, family_id, order_id) %>%
  summarise(number_of_samples = n(), .groups = "drop") %>%
  arrange(host_order, host_family, host_genus, host_species)

family_summary <- species_summary %>%
  group_by(host_order, host_family, family_id) %>%
  summarise(number_of_samples = sum(number_of_samples), .groups = "drop") %>%
  arrange(host_order, host_family)

order_summary <- species_summary %>%
  group_by(host_order, order_id) %>%
  summarise(number_of_samples = sum(number_of_samples), .groups = "drop") %>%
  arrange(host_order)

# =========================
# 1. Labels：物种显示正常名；属节点标签设为空
# =========================

label_df_species <- species_summary %>%
  distinct(id = species_id, label = host_species)

label_df_genus_blank <- species_summary %>%
  distinct(id = genus_id) %>%
  mutate(label = "")

label_df_family <- family_summary %>%
  mutate(label = paste0(host_family, " n=", number_of_samples)) %>%
  distinct(id = family_id, label)

label_df_order <- order_summary %>%
  distinct(id = order_id, label = host_order)

label_df <- bind_rows(
  tibble(id = "root", label = ""),
  label_df_order,
  label_df_family,
  label_df_genus_blank,
  label_df_species
) %>%
  distinct(id, .keep_all = TRUE)

writeLines(
  c(
    "LABELS",
    "SEPARATOR TAB",
    "DATA",
    paste(label_df$id, label_df$label, sep = "\t")
  ),
  out_labels
)

# =========================
# 2. Internal labels：只显示目和科，不显示属
# =========================

internal_df <- bind_rows(
  order_summary %>%
    transmute(id = order_id, label = host_order),
  family_summary %>%
    transmute(id = family_id, label = paste0(host_family, " n=", number_of_samples))
) %>%
  distinct(id, .keep_all = TRUE)

writeLines(
  c(
    "DATASET_TEXT",
    "SEPARATOR TAB",
    "DATASET_LABEL\tTaxonomic labels",
    "COLOR\t#000000",
    "DATA",
    paste(
      internal_df$id,
      internal_df$label,
      "0",
      "#000000",
      "normal",
      "1",
      "0",
      sep = "\t"
    )
  ),
  out_internal_labels
)

# =========================
# 3. Samples text
# DATASET_TEXT 每行格式：
# node_id, text, position, color, style, size, rotation
# =========================

writeLines(
  c(
    "DATASET_TEXT",
    "SEPARATOR TAB",
    "DATASET_LABEL\tSamples",
    "COLOR\t#000000",
    "DATA",
    paste(
      species_summary$species_id,
      species_summary$number_of_samples,
      "1",
      "#000000",
      "normal",
      "1",
      "0",
      sep = "\t"
    )
  ),
  out_samples_text
)

# =========================
# 4. Status pie
# DATASET_PIECHART 每行格式：
# node_id, position, radius, value1, value2, ...
# =========================

df_status <- df2 %>%
  mutate(
    status2 = case_when(
      tolower(status) == "domesticated" ~ "Domesticated",
      tolower(status) == "captive" ~ "Captive",
      tolower(status) == "wild" ~ "Wild",
      TRUE ~ "Unknown"
    )
  )

status_levels <- c("Domesticated", "Captive", "Wild", "Unknown")
status_colors <- c("#14BFC6", "#F26B6B", "#FDB45C", "#BDBDBD")

status_wide <- df_status %>%
  count(species_id, status2, name = "n") %>%
  complete(
    species_id = unique(species_summary$species_id),
    status2 = status_levels,
    fill = list(n = 0)
  ) %>%
  pivot_wider(names_from = status2, values_from = n, values_fill = 0) %>%
  arrange(species_id)

for (s in status_levels) {
  if (!s %in% colnames(status_wide)) status_wide[[s]] <- 0
}
status_wide <- status_wide[, c("species_id", status_levels)]

status_data <- apply(status_wide, 1, function(x) {
  paste(
    c(
      x[["species_id"]],
      "-1",
      "20",
      as.character(as.integer(as.numeric(x[status_levels])))
    ),
    collapse = "\t"
  )
})

writeLines(
  c(
    "DATASET_PIECHART",
    "SEPARATOR TAB",
    "DATASET_LABEL\tStatus",
    "COLOR\t#000000",
    paste0("FIELD_LABELS\t", paste(status_levels, collapse = "\t")),
    paste0("FIELD_COLORS\t", paste(status_colors, collapse = "\t")),
    "MAXIMUM_SIZE\t30",
    "DATA",
    status_data
  ),
  out_status_pie
)

# =========================
# 5. Country pie
# =========================

country_levels <- df2 %>%
  count(country, name = "n") %>%
  arrange(desc(n), country) %>%
  pull(country)

if (length(country_levels) <= 12) {
  country_colors <- brewer.pal(max(3, length(country_levels)), "Set3")[seq_along(country_levels)]
} else {
  country_colors <- colorRampPalette(brewer.pal(12, "Set3"))(length(country_levels))
}

country_wide <- df2 %>%
  count(species_id, country, name = "n") %>%
  complete(
    species_id = unique(species_summary$species_id),
    country = country_levels,
    fill = list(n = 0)
  ) %>%
  pivot_wider(names_from = country, values_from = n, values_fill = 0) %>%
  arrange(species_id)

for (cc in country_levels) {
  if (!cc %in% colnames(country_wide)) country_wide[[cc]] <- 0
}
country_wide <- country_wide[, c("species_id", country_levels)]

country_data <- apply(country_wide, 1, function(x) {
  paste(
    c(
      x[["species_id"]],
      "-1",
      "20",
      as.character(as.integer(as.numeric(x[country_levels])))
    ),
    collapse = "\t"
  )
})

writeLines(
  c(
    "DATASET_PIECHART",
    "SEPARATOR TAB",
    "DATASET_LABEL\tCountry",
    "COLOR\t#000000",
    paste0("FIELD_LABELS\t", paste(country_levels, collapse = "\t")),
    paste0("FIELD_COLORS\t", paste(country_colors, collapse = "\t")),
    "MAXIMUM_SIZE\t30",
    "DATA",
    country_data
  ),
  out_country_pie
)

cat("\nDone!\n")
cat("Output directory:\n", out_dir, "\n\n")
cat("Files generated:\n")
cat(out_labels, "\n")
cat(out_internal_labels, "\n")
cat(out_samples_text, "\n")
cat(out_status_pie, "\n")
cat(out_country_pie, "\n")
EOF
#然后直接运行：
Rscript globalfungi_style_test/scripts/make_itol_annotations_final_SH_v4.R
