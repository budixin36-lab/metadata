#!/usr/bin/env bash
set -euo pipefail

THREADS=4

mkdir -p qza logs qzv

run_paired () {
    region=$1
    manifest="manifests/manifest_paired_${region}.tsv"

    demux="qza/paired_${region}_demux.qza"
    trimmed="qza/paired_${region}_itsxpress.qza"
    table="qza/paired_${region}_derep_table.qza"
    repseqs="qza/paired_${region}_derep_repseqs.qza"

    n=$(($(wc -l < "$manifest") - 1))
    if [[ "$n" -le 0 ]]; then
        echo "[SKIP] paired $region has no samples"
        return
    fi

    echo "[IMPORT] paired $region, samples=$n"
    if [[ ! -s "$demux" ]]; then
        qiime tools import \
          --type 'SampleData[PairedEndSequencesWithQuality]' \
          --input-path "$manifest" \
          --output-path "$demux" \
          --input-format PairedEndFastqManifestPhred33V2 \
          > "logs/import_paired_${region}.log" 2>&1
    else
        echo "[SKIP] $demux exists"
    fi

    echo "[SUMMARIZE DEMUX] paired $region"
    if [[ ! -s "qzv/paired_${region}_demux.qzv" ]]; then
        qiime demux summarize \
          --i-data "$demux" \
          --o-visualization "qzv/paired_${region}_demux.qzv" \
          > "logs/summarize_demux_paired_${region}.log" 2>&1
    fi

    echo "[ITSxpress] paired $region"
    if [[ ! -s "$trimmed" ]]; then
        qiime itsxpress trim-pair \
          --i-per-sample-sequences "$demux" \
          --p-region "$region" \
          --p-taxa F \
          --p-cluster-id 1.0 \
          --p-threads "$THREADS" \
          --o-trimmed "$trimmed" \
          > "logs/itsxpress_paired_${region}.log" 2>&1
    else
        echo "[SKIP] $trimmed exists"
    fi

    echo "[SUMMARIZE TRIMMED] paired $region"
    if [[ ! -s "qzv/paired_${region}_itsxpress.qzv" ]]; then
        qiime demux summarize \
          --i-data "$trimmed" \
          --o-visualization "qzv/paired_${region}_itsxpress.qzv" \
          > "logs/summarize_itsxpress_paired_${region}.log" 2>&1
    fi

    echo "[DEREP] paired $region"
    if [[ ! -s "$table" || ! -s "$repseqs" ]]; then
        qiime vsearch dereplicate-sequences \
          --i-sequences "$trimmed" \
          --p-min-seq-length 1 \
          --p-min-unique-size 1 \
          --o-dereplicated-table "$table" \
          --o-dereplicated-sequences "$repseqs" \
          > "logs/derep_paired_${region}.log" 2>&1
    else
        echo "[SKIP] derep paired $region exists"
    fi

    echo "[SUMMARIZE DEREP TABLE] paired $region"
    if [[ ! -s "qzv/paired_${region}_derep_table.qzv" ]]; then
        qiime feature-table summarize \
          --i-table "$table" \
          --o-visualization "qzv/paired_${region}_derep_table.qzv" \
          --m-sample-metadata-file metadata/metadata_valid.tsv \
          > "logs/summarize_derep_table_paired_${region}.log" 2>&1 || \
        qiime feature-table summarize \
          --i-table "$table" \
          --o-visualization "qzv/paired_${region}_derep_table.qzv" \
          > "logs/summarize_derep_table_paired_${region}.log" 2>&1
    fi

    echo "[TABULATE REPSEQS] paired $region"
    if [[ ! -s "qzv/paired_${region}_derep_repseqs.qzv" ]]; then
        qiime feature-table tabulate-seqs \
          --i-data "$repseqs" \
          --o-visualization "qzv/paired_${region}_derep_repseqs.qzv" \
          > "logs/tabulate_repseqs_paired_${region}.log" 2>&1
    fi
}

