#把下面整段粘贴进去：
#!/usr/bin/env bash
set -euo pipefail

cd /mnt/d/ITS_SH_pipeline

# =========================
# GlobalFungi-style batch run
# =========================

workdir="globalfungi_style_test"
fasta_dir="${workdir}/fasta"
ref_dir="${workdir}/ref"
blast_dir="${workdir}/blast"
table_dir="${workdir}/tables"
result_dir="${workdir}/results"
script_dir="${workdir}/scripts"
log_dir="${workdir}/logs"

mkdir -p "$fasta_dir" "$ref_dir" "$blast_dir" "$table_dir" "$result_dir" "$script_dir" "$log_dir"

ref_fasta="${ref_dir}/UNITE_SH_reps.fasta"
blast_db="${ref_dir}/UNITE_SH"

threads=4

echo "===== GlobalFungi-style batch run started ====="
date

# =========================
# Check tools
# =========================

command -v qiime >/dev/null 2>&1 || { echo "ERROR: qiime not found. Please conda activate qiime2-amplicon-2026.1"; exit 1; }
command -v blastn >/dev/null 2>&1 || { echo "ERROR: blastn not found. Install with: conda install -c bioconda blast -y"; exit 1; }
command -v makeblastdb >/dev/null 2>&1 || { echo "ERROR: makeblastdb not found. Install with: conda install -c bioconda blast -y"; exit 1; }

# =========================
# Prepare reference
# =========================

if [ ! -s "reference/UNITE_SH_reps.fasta" ]; then
  echo "ERROR: reference/UNITE_SH_reps.fasta not found"
  exit 1
fi

if [ ! -s "$ref_fasta" ]; then
  cp reference/UNITE_SH_reps.fasta "$ref_fasta"
fi

echo "UNITE SH reference sequences:"
grep -c "^>" "$ref_fasta"

if [ ! -s "${blast_db}.nin" ] && [ ! -s "${blast_db}.ndb" ]; then
  echo "Building BLAST database..."
  makeblastdb \
    -in "$ref_fasta" \
    -dbtype nucl \
    -out "$blast_db"
else
  echo "BLAST database already exists."
fi

# =========================
# Write helper scripts
# =========================

cat > "${script_dir}/filter_fasta_min40_noambig.awk" <<'EOF'
BEGIN {
  header = ""
  seq = ""
}

function process_record() {
  if (header == "") return

  s = toupper(seq)

  if (length(s) >= 40 && s ~ /^[ACGT]+$/) {
    print header
    print s
  }
}

/^>/ {
  process_record()
  header = $0
  seq = ""
  next
}

{
  seq = seq $0
}

END {
  process_record()
}
EOF

cat > "${script_dir}/filter_best_blast_globalfungi_style.py" <<'EOF'
#!/usr/bin/env python3

import csv
import sys

infile = sys.argv[1]
outfile = sys.argv[2]

MIN_PIDENT = 98.5
MIN_QCOV = 90.0
MAX_EVALUE = 1e-50

best = {}

with open(infile, "r", newline="") as f:
    reader = csv.reader(f, delimiter="\t")

    for row in reader:
        if len(row) < 13:
            continue

        qseqid = row[0]
        sseqid = row[1]
        pident = float(row[2])
        aln_len = int(row[3])
        qlen = int(row[4])
        slen = int(row[5])
        qstart = int(row[6])
        qend = int(row[7])
        sstart = int(row[8])
        send = int(row[9])
        evalue = float(row[10])
        bitscore = float(row[11])
        qcovs = float(row[12])

        if pident < MIN_PIDENT:
            continue
        if qcovs < MIN_QCOV:
            continue
        if evalue > MAX_EVALUE:
            continue

        record = {
            "qseqid": qseqid,
            "sseqid": sseqid,
            "pident": pident,
            "aln_len": aln_len,
            "qlen": qlen,
            "slen": slen,
            "qstart": qstart,
            "qend": qend,
            "sstart": sstart,
            "send": send,
            "evalue": evalue,
            "bitscore": bitscore,
            "qcovs": qcovs,
        }

        if qseqid not in best:
            best[qseqid] = record
        else:
            old = best[qseqid]
            if (
                bitscore > old["bitscore"]
                or (bitscore == old["bitscore"] and evalue < old["evalue"])
                or (bitscore == old["bitscore"] and evalue == old["evalue"] and pident > old["pident"])
            ):
                best[qseqid] = record

with open(outfile, "w", newline="") as out:
    writer = csv.writer(out, delimiter="\t")
    writer.writerow([
        "feature_id",
        "sh_id",
        "pident",
        "qcovs",
        "evalue",
        "bitscore",
        "alignment_length",
        "query_length",
        "subject_length"
    ])

    for qseqid in sorted(best):
        r = best[qseqid]
        writer.writerow([
            r["qseqid"],
            r["sseqid"],
            r["pident"],
            r["qcovs"],
            r["evalue"],
            r["bitscore"],
            r["aln_len"],
            r["qlen"],
            r["slen"],
        ])

print(f"Kept best hits: {len(best)}")
EOF

cat > "${script_dir}/collapse_biom_to_SH_sparse.py" <<'EOF'
#!/usr/bin/env python3

import sys
import csv
from biom import load_table
from biom.util import biom_open

best_hits_file = sys.argv[1]
biom_file = sys.argv[2]
out_biom = sys.argv[3]
stats_file = sys.argv[4]

feature_to_sh = {}

with open(best_hits_file, "r", newline="") as f:
    reader = csv.DictReader(f, delimiter="\t")
    for row in reader:
        feature_to_sh[row["feature_id"]] = row["sh_id"]

print(f"Mapped features in best-hit file: {len(feature_to_sh)}")

print("Loading BIOM table...")
table = load_table(biom_file)

total_features = len(table.ids(axis="observation"))
print(f"Total features in BIOM table: {total_features}")

mapped_ids = [fid for fid in table.ids(axis="observation") if fid in feature_to_sh]
print(f"Mapped features present in BIOM table: {len(mapped_ids)}")

print("Filtering table to mapped features only...")
mapped_table = table.filter(mapped_ids, axis="observation", inplace=False)

print("Adding SH metadata...")
obs_metadata = {
    fid: {"SH_ID": feature_to_sh[fid]}
    for fid in mapped_table.ids(axis="observation")
}
mapped_table.add_metadata(obs_metadata, axis="observation")

print("Collapsing features to SH level...")
sh_table = mapped_table.collapse(
    lambda id_, md: md["SH_ID"],
    axis="observation",
    norm=False,
    include_collapsed_metadata=False
)

print("Writing SH BIOM table...")
with biom_open(out_biom, "w") as f:
    sh_table.to_hdf5(f, generated_by="collapse_biom_to_SH_sparse.py")

with open(stats_file, "w") as s:
    s.write(f"total_features_in_table\t{total_features}\n")
    s.write(f"mapped_features_in_best_hit_file\t{len(feature_to_sh)}\n")
    s.write(f"mapped_features_present_in_table\t{len(mapped_ids)}\n")
    s.write(f"unmapped_features_in_table\t{total_features - len(mapped_ids)}\n")
    if total_features > 0:
        s.write(f"mapped_feature_percent\t{len(mapped_ids) / total_features * 100:.4f}\n")
    s.write(f"SH_count\t{len(sh_table.ids(axis='observation'))}\n")
    s.write(f"sample_count\t{len(sh_table.ids(axis='sample'))}\n")

print(f"Done: {out_biom}")
print(f"Stats: {stats_file}")
EOF

chmod +x "${script_dir}/filter_best_blast_globalfungi_style.py"
chmod +x "${script_dir}/collapse_biom_to_SH_sparse.py"

# =========================
# Batch process
# =========================

summary="${result_dir}/all_globalfungi_style_mapping_summary.tsv"
echo -e "base\ttotal_features\tmapped_features\tmapped_percent\tSH_count\tsample_count" > "$summary"

for repseq_qza in qza/*_derep_repseqs.qza
do
  base=$(basename "$repseq_qza" _derep_repseqs.qza)
  table_qza="qza/${base}_derep_table.qza"

  raw_fasta="${fasta_dir}/${base}_derep_repseqs.fasta"
  filtered_fasta="${fasta_dir}/${base}_min40_noambig.fasta"
  blast_out="${blast_dir}/${base}_vs_UNITE_SH.outfmt6"

  best_hits="${result_dir}/${base}_best_hits_globalfungi_style.tsv"
  table_export_dir="${table_dir}/${base}_derep_table_exported"
  sh_biom="${result_dir}/${base}_SH_table_globalfungi_style.biom"
  stats_file="${result_dir}/${base}_SH_mapping_stats.txt"
  run_log="${log_dir}/${base}_run.log"

  echo
  echo "============================================================"
  echo "Processing: $base"
  echo "============================================================"

  {
    echo "===== Start $base ====="
    date
  } | tee "$run_log"

  if [ ! -s "$table_qza" ]; then
    echo "WARNING: missing table file: $table_qza. Skip $base." | tee -a "$run_log"
    continue
  fi

  # 断点续跑：如果最终结果已存在，就跳过
  if [ -s "$sh_biom" ] && [ -s "$stats_file" ] && [ -s "$best_hits" ]; then
    echo "Final outputs already exist. Skip $base." | tee -a "$run_log"

    total=$(awk -F'\t' '$1=="total_features_in_table"{print $2}' "$stats_file")
    mapped=$(awk -F'\t' '$1=="mapped_features_present_in_table"{print $2}' "$stats_file")
    percent=$(awk -F'\t' '$1=="mapped_feature_percent"{print $2}' "$stats_file")
    shn=$(awk -F'\t' '$1=="SH_count"{print $2}' "$stats_file")
    sn=$(awk -F'\t' '$1=="sample_count"{print $2}' "$stats_file")
    echo -e "${base}\t${total}\t${mapped}\t${percent}\t${shn}\t${sn}" >> "$summary"

    continue
  fi

  echo "Exporting repseqs..." | tee -a "$run_log"
  unzip -p "$repseq_qza" '*/data/dna-sequences.fasta' > "$raw_fasta"

  echo "Raw representative sequences:" | tee -a "$run_log"
  grep -c "^>" "$raw_fasta" | tee -a "$run_log"

  echo "Filtering sequences: length >=40 bp and A/C/G/T only..." | tee -a "$run_log"
  awk -f "${script_dir}/filter_fasta_min40_noambig.awk" \
    "$raw_fasta" \
    > "$filtered_fasta"

  echo "Filtered representative sequences:" | tee -a "$run_log"
  grep -c "^>" "$filtered_fasta" | tee -a "$run_log"

  echo "Running BLASTn..." | tee -a "$run_log"
  blastn \
    -query "$filtered_fasta" \
    -db "$blast_db" \
    -out "$blast_out" \
    -evalue 1e-5 \
    -outfmt "6 qseqid sseqid pident length qlen slen qstart qend sstart send evalue bitscore qcovs" \
    -num_threads "$threads" \
    -max_target_seqs 10 \
    2>&1 | tee -a "$run_log"

  echo "BLAST output lines:" | tee -a "$run_log"
  wc -l "$blast_out" | tee -a "$run_log"

  echo "Filtering best hits..." | tee -a "$run_log"
  python "${script_dir}/filter_best_blast_globalfungi_style.py" \
    "$blast_out" \
    "$best_hits" \
    2>&1 | tee -a "$run_log"

  echo "Best-hit file lines including header:" | tee -a "$run_log"
  wc -l "$best_hits" | tee -a "$run_log"

  echo "Exporting derep table..." | tee -a "$run_log"
  rm -rf "$table_export_dir"

  qiime tools export \
    --input-path "$table_qza" \
    --output-path "$table_export_dir" \
    2>&1 | tee -a "$run_log"

  echo "Collapsing BIOM feature table to SH table..." | tee -a "$run_log"

  python "${script_dir}/collapse_biom_to_SH_sparse.py" \
    "$best_hits" \
    "${table_export_dir}/feature-table.biom" \
    "$sh_biom" \
    "$stats_file" \
    2>&1 | tee -a "$run_log"

  echo "Mapping stats:" | tee -a "$run_log"
  cat "$stats_file" | tee -a "$run_log"

  if [ -s "$sh_biom" ] && [ -s "$stats_file" ] && [ -s "$best_hits" ]; then
    echo "Final outputs exist. Cleaning temporary files for $base ..." | tee -a "$run_log"

    rm -f "$raw_fasta"
    rm -f "$filtered_fasta"
    rm -f "$blast_out"
    rm -rf "$table_export_dir"

    echo "Temporary files cleaned." | tee -a "$run_log"
  else
    echo "WARNING: final outputs missing for $base. Temporary files were kept." | tee -a "$run_log"
  fi

  total=$(awk -F'\t' '$1=="total_features_in_table"{print $2}' "$stats_file")
  mapped=$(awk -F'\t' '$1=="mapped_features_present_in_table"{print $2}' "$stats_file")
  percent=$(awk -F'\t' '$1=="mapped_feature_percent"{print $2}' "$stats_file")
  shn=$(awk -F'\t' '$1=="SH_count"{print $2}' "$stats_file")
  sn=$(awk -F'\t' '$1=="sample_count"{print $2}' "$stats_file")

  echo -e "${base}\t${total}\t${mapped}\t${percent}\t${shn}\t${sn}" >> "$summary"

  {
    echo "===== Finished $base ====="
    date
  } | tee -a "$run_log"

done

echo
echo "===== GlobalFungi-style batch run finished ====="
date

echo "Summary saved to:"
echo "$summary"

cat "$summary"
