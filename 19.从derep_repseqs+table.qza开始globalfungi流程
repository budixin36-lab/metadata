#!/usr/bin/env python3

import csv
import sys

infile = sys.argv[1]
outfile = sys.argv[2]

MIN_PIDENT = 98.5
MIN_QCOV = 90.0
MAX_EVALUE = 1e-50

best = {}

with open(infile, "r", newline="") as f:
    reader = csv.reader(f, delimiter="\t")

    for row in reader:
        if len(row) < 13:
            continue

        qseqid = row[0]
        sseqid = row[1]
        pident = float(row[2])
        aln_len = int(row[3])
        qlen = int(row[4])
        slen = int(row[5])
        qstart = int(row[6])
        qend = int(row[7])
        sstart = int(row[8])
        send = int(row[9])
        evalue = float(row[10])
        bitscore = float(row[11])
        qcovs = float(row[12])

        if pident < MIN_PIDENT:
            continue
        if qcovs < MIN_QCOV:
            continue
        if evalue > MAX_EVALUE:
            continue

        record = {
            "qseqid": qseqid,
            "sseqid": sseqid,
            "pident": pident,
            "aln_len": aln_len,
            "qlen": qlen,
            "slen": slen,
