#!/usr/bin/env python3

import csv
import sys
from collections import defaultdict

blast_best_file = sys.argv[1]
feature_table_file = sys.argv[2]
out_file = sys.argv[3]
stats_file = sys.argv[4]

feature_to_sh = {}

with open(blast_best_file, "r", newline="") as f:
    reader = csv.DictReader(f, delimiter="\t")
    for row in reader:
        feature_to_sh[row["feature_id"]] = row["sh_id"]

sample_ids = []
sh_counts = defaultdict(lambda: defaultdict(float))

total_features_in_table = 0
mapped_features_in_table = 0
unmapped_features_in_table = 0

with open(feature_table_file, "r", newline="") as f:
    for line in f:
        if line.startswith("# Constructed from biom file"):
            continue

        if line.startswith("#OTU ID"):
            header = line.rstrip("\n").split("\t")
            sample_ids = header[1:]
            continue

        if line.startswith("#"):
            continue

        parts = line.rstrip("\n").split("\t")
        if len(parts) < 2:
            continue

        feature_id = parts[0]
        counts = parts[1:]

        total_features_in_table += 1

        if feature_id not in feature_to_sh:
            unmapped_features_in_table += 1
            continue

        mapped_features_in_table += 1
        sh_id = feature_to_sh[feature_id]

        for sample, count in zip(sample_ids, counts):
            try:
                value = float(count)
            except ValueError:
                value = 0.0

            if value != 0:
                sh_counts[sh_id][sample] += value

with open(out_file, "w", newline="") as out:
    writer = csv.writer(out, delimiter="\t")
    writer.writerow(["SH_ID"] + sample_ids)

    for sh_id in sorted(sh_counts):
        row = [sh_id]
        for sample in sample_ids:
            value = sh_counts[sh_id].get(sample, 0.0)
            if value.is_integer():
                value = int(value)
            row.append(value)
        writer.writerow(row)

with open(stats_file, "w") as s:
    s.write(f"total_features_in_table\t{total_features_in_table}\n")
    s.write(f"mapped_features_in_table\t{mapped_features_in_table}\n")
    s.write(f"unmapped_features_in_table\t{unmapped_features_in_table}\n")
    if total_features_in_table > 0:
        s.write(f"mapped_feature_percent\t{mapped_features_in_table / total_features_in_table * 100:.4f}\n")

print(f"Output SH table: {out_file}")
print(f"Stats: {stats_file}")
