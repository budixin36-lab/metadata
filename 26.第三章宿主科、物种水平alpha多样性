plot_alpha_box <- function(df, group_col, output_prefix, x_angle = 30) {
  plot_df <- df %>%
    select(all_of(group_col), all_of(metrics)) %>%
    pivot_longer(
      cols = all_of(metrics),
      names_to = "metric",
      values_to = "value"
    ) %>%
    filter(!is.na(value), !is.na(.data[[group_col]]), .data[[group_col]] != "")

  group_order <- df %>%
    count(.data[[group_col]], sort = TRUE) %>%
    pull(.data[[group_col]])

  plot_df[[group_col]] <- factor(plot_df[[group_col]], levels = group_order)
  plot_df$metric <- factor(plot_df$metric, levels = metrics)

  p <- ggplot(plot_df, aes(x = .data[[group_col]], y = value, fill = .data[[group_col]])) +
    geom_boxplot(width = 0.65, outlier.shape = NA) +
    facet_wrap(~ metric, scales = "free_y", ncol = 2) +
    labs(
      x = NULL,
      y = "Alpha diversity index"
    ) +
    theme_classic(base_size = 12) +
    theme(
      axis.text.x = element_text(angle = x_angle, hjust = 1),
      legend.position = "none",
      strip.background = element_blank(),
      strip.text = element_text(size = 12)
    )

  ggsave(
    file.path(out_dir, paste0(output_prefix, ".pdf")),
    p,
    width = ifelse(group_col == "host_species", 12, 8),
    height = ifelse(group_col == "host_species", 7, 6)
  )

  ggsave(
    file.path(out_dir, paste0(output_prefix, ".png")),
    p,
    width = ifelse(group_col == "host_species", 12, 8),
    height = ifelse(group_col == "host_species", 7, 6),
    dpi = 300
  )
}

