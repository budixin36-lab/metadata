make_alpha_summary <- function(df, group_col) {
  df %>%
    group_by(.data[[group_col]]) %>%
    summarise(
      n = n(),
      ACE_mean = mean(ACE, na.rm = TRUE),
      ACE_sd = sd(ACE, na.rm = TRUE),
