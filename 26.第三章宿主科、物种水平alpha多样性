      Chao1_sd = sd(Chao1, na.rm = TRUE),
      Shannon_mean = mean(Shannon, na.rm = TRUE),
      Shannon_sd = sd(Shannon, na.rm = TRUE),
      Simpson_mean = mean(Simpson, na.rm = TRUE),
      Simpson_sd = sd(Simpson, na.rm = TRUE),
      ACE_mean_sd = sprintf("%.2f ± %.2f", ACE_mean, ACE_sd),
      Chao1_mean_sd = sprintf("%.2f ± %.2f", Chao1_mean, Chao1_sd),
      Shannon_mean_sd = sprintf("%.2f ± %.2f", Shannon_mean, Shannon_sd),
      Simpson_mean_sd = sprintf("%.4f ± %.4f", Simpson_mean, Simpson_sd),
      .groups = "drop"
    ) %>%
    arrange(desc(n))
}

# -----------------------------
# 5. ANOVA table
# -----------------------------
run_anova_table <- function(df, group_col, metrics) {
  out <- list()

  for (m in metrics) {
    dat <- df %>%
      select(value = all_of(m), group = all_of(group_col)) %>%
      filter(!is.na(value), !is.na(group), group != "")

    dat$group <- factor(dat$group)

    fit <- aov(value ~ group, data = dat)
    sm <- summary(fit)[[1]]

    p <- sm["group", "Pr(>F)"]

    out[[m]] <- data.frame(
      metric = m,
      group_variable = group_col,
      Df_between = sm["group", "Df"],
      Df_within = sm["Residuals", "Df"],
      F_value = sm["group", "F value"],
      P_value = p,
      significance = case_when(
        p < 0.001 ~ "***",
        p < 0.01 ~ "**",
        p < 0.05 ~ "*",
        TRUE ~ "ns"
      ),
      stringsAsFactors = FALSE
    )
  }

  bind_rows(out)
}

# -----------------------------
# 6. TukeyHSD table
# -----------------------------
run_tukey_table <- function(df, group_col, metrics, only_significant = FALSE) {
  out <- list()

  for (m in metrics) {
    dat <- df %>%
      select(value = all_of(m), group = all_of(group_col)) %>%
      filter(!is.na(value), !is.na(group), group != "")

    dat$group <- factor(dat$group)

    fit <- aov(value ~ group, data = dat)
    tk <- TukeyHSD(fit)$group

    tk_df <- as.data.frame(tk) %>%
      rownames_to_column("comparison") %>%
      mutate(
        metric = m,
        group_variable = group_col,
        significance = case_when(
          `p adj` < 0.001 ~ "***",
          `p adj` < 0.01 ~ "**",
          `p adj` < 0.05 ~ "*",
          TRUE ~ "ns"
        )
      ) %>%
      select(
        metric,
        group_variable,
        comparison,
        diff,
        lwr,
        upr,
        p_adj = `p adj`,
        significance
      )

    if (only_significant) {
      tk_df <- tk_df %>% filter(p_adj < 0.05)
    }

    out[[m]] <- tk_df
  }

  bind_rows(out)
}

