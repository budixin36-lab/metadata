      label = p_label,
      hjust = 1,
      vjust = 1,
      size = 4.5
    ) +
    scale_y_continuous(
      limits = c(0, y_upper),
      expand = expansion(mult = c(0, 0.02))
    ) +
    labs(
      x = "Host family",
      y = metric_name
    ) +
    theme_classic(base_size = 14) +
    theme(
      axis.text.x = element_text(angle = 35, hjust = 1, vjust = 1),
      axis.title.x = element_text(size = 14),
      axis.title.y = element_text(size = 15),
      legend.position = "none"
    )

  ggsave(
    file.path(out_dir, paste0("Fig3_6_host_family_alpha_", metric_name, "_boxplot_outliers_ANOVA_P.pdf")),
    p,
    width = 6.5,
    height = 5
  )

  ggsave(
    file.path(out_dir, paste0("Fig3_6_host_family_alpha_", metric_name, "_boxplot_outliers_ANOVA_P.png")),
    p,
    width = 6.5,
    height = 5,
    dpi = 300
  )
}

for (m in metrics) {
  plot_one_metric(m)
}

cat("\nDone!\n")
cat("Output directory:\n", out_dir, "\n")
cat("Generated separate host_family alpha diversity plots with outliers and ANOVA P values.\n")
EOF
