      select(value = all_of(m), group = all_of(group_col)) %>%
      filter(!is.na(value), !is.na(group), group != "")

    dat$group <- factor(dat$group)

    fit <- aov(value ~ group, data = dat)
    tk <- TukeyHSD(fit)$group

    tk_df <- as.data.frame(tk) %>%
      rownames_to_column("comparison") %>%
      mutate(
        metric = m,
        group_variable = group_col,
        significance = case_when(
          `p adj` < 0.001 ~ "***",
          `p adj` < 0.01 ~ "**",
          `p adj` < 0.05 ~ "*",
          TRUE ~ "ns"
        )
      ) %>%
      select(
        metric,
        group_variable,
        comparison,
        diff,
        lwr,
        upr,
        p_adj = `p adj`,
        significance
      )

    if (only_significant) {
      tk_df <- tk_df %>% filter(p_adj < 0.05)
    }

    out[[m]] <- tk_df
  }

  bind_rows(out)
}

