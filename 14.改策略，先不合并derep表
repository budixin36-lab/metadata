import re
from pathlib import Path

infile = Path("reference/sh_general_release_dynamic_19.02.2025.fasta")
out_fa = Path("reference/UNITE_SH_reps.fasta")
out_tax = Path("reference/UNITE_SH_taxonomy.tsv")
out_tax_noheader = Path("reference/UNITE_SH_taxonomy_noheader.tsv")

if not infile.exists():
    raise SystemExit(f"Cannot find {infile}")

seen = set()
current_keep = False

with open(infile, "r", encoding="utf-8", errors="ignore") as fin, \
     open(out_fa, "w") as fout, \
     open(out_tax, "w") as ftax, \
     open(out_tax_noheader, "w") as ftax_noheader:

    ftax.write("Feature ID\tTaxon\n")

    for line in fin:
        line = line.rstrip("\n")

        if line.startswith(">"):
            header = line[1:]

            m = re.search(r"(SH\d+\.\d+[A-Z]+)", header)
            if not m:
                current_keep = False
                continue

            sh = m.group(1)

            km = re.search(r"(k__.+)$", header)
            if km:
                tax = km.group(1)
            else:
                tax = "k__Fungi"

            if sh in seen:
                current_keep = False
                continue

            seen.add(sh)
            current_keep = True

            fout.write(f">{sh}\n")
            ftax.write(f"{sh}\t{tax}\n")
            ftax_noheader.write(f"{sh}\t{tax}\n")

        else:
            if current_keep:
                seq = line.strip()
                if seq:
                    fout.write(seq + "\n")

print(f"Wrote: {out_fa}")
print(f"Wrote: {out_tax}")
print(f"Wrote: {out_tax_noheader}")
print(f"Number of unique SH IDs: {len(seen)}")
PY

