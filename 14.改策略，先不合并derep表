#1. 新建 SH mapping 脚本
cd /mnt/d/ITS_SH_pipeline

cat > scripts/07_map_each_derep_to_unite_SH.sh <<'BASH'
#!/usr/bin/env bash
set -euo pipefail

THREADS=4

export TMPDIR="/tmp"
export TMP="/tmp"
export TEMP="/tmp"

mkdir -p qza logs

REF="qza/UNITE_SH_reps.qza"

if [[ ! -s "$REF" ]]; then
    echo "ERROR: cannot find $REF"
    exit 1
fi

for table in qza/*derep_table.qza
do
    base=$(basename "$table" _derep_table.qza)
    repseqs="qza/${base}_derep_repseqs.qza"

    out_table="qza/${base}_SH_table.qza"
    out_repseqs="qza/${base}_SH_repseqs.qza"
    out_unmatched="qza/${base}_unmatched_repseqs.qza"

    if [[ ! -s "$repseqs" ]]; then
        echo "[SKIP] missing repseqs for $base"
        continue
    fi

    if [[ -s "$out_table" && -s "$out_repseqs" && -s "$out_unmatched" ]]; then
        echo "[SKIP] $base SH mapping already exists"
        continue
    fi

    echo "========================================"
    echo "[SH MAPPING] $base"
    echo "========================================"

    qiime vsearch cluster-features-closed-reference \
      --i-table "$table" \
      --i-sequences "$repseqs" \
      --i-reference-sequences "$REF" \
      --p-perc-identity 0.97 \
      --p-strand both \
      --p-threads "$THREADS" \
      --o-clustered-table "$out_table" \
      --o-clustered-sequences "$out_repseqs" \
      --o-unmatched-sequences "$out_unmatched" \
      > "logs/SH_mapping_${base}.log" 2>&1

    rm -rf /tmp/qiime2*

    echo "[DONE] $base"
    ls -lh "$out_table" "$out_repseqs" "$out_unmatched"
done

echo "All per-group SH mappings finished."
BASH

