#3. 单个文件确认没问题后，批量处理全部文件
#先新建输出文件夹：
mkdir -p ../PRJNA1085887_q2q41
#批量处理：
python3 - <<'PY'
import gzip
from pathlib import Path

qmin = 2
qmax = 41
offset = 33

outdir = Path("../PRJNA1085887_q2q41")
outdir.mkdir(exist_ok=True)

for inp in sorted(Path(".").glob("*_subreads.fastq.gz")):
    out = outdir / inp.name.replace(".fastq.gz", "_q2q41.fastq.gz")
    print("Processing", inp, "->", out)

    with gzip.open(inp, "rt") as fin, gzip.open(out, "wt") as fout:
        while True:
            h = fin.readline()
            if not h:
                break
            seq = fin.readline()
            plus = fin.readline()
            qual = fin.readline().rstrip("\n\r")

            newqual = "".join(
                chr(min(max(ord(c) - offset, qmin), qmax) + offset)
                for c in qual
            )

            fout.write(h)
            fout.write(seq)
            fout.write(plus)
            fout.write(newqual + "\n")

print("All done.")
PY
