import pandas as pd
from pathlib import Path

meta = pd.read_csv("metadata/metadata_valid.csv", dtype=str)
mr = pd.read_csv("results/SH_mapping_rate_by_sample.tsv", sep="\t", dtype=str)

problem_bps = [
    "PRJNA695353", "PRJNA566442", "PRJNA745381",
    "PRJNA599105", "PRJNA511363", "PRJNA380769"
]

manifest_files = list(Path("manifests").glob("*.tsv")) + list(Path("manifests/batches/paired_ITS1").glob("*.tsv"))

for bp in problem_bps:
    sub = meta[meta["BioProject"] == bp]
    print("\n======", bp, "======")
    print("metadata samples:", len(sub))
    print("with mapping rate:", sub["sampleid"].isin(mr["sampleid"]).sum())

    in_manifest = 0
    not_in_manifest = []
    for sid in sub["sampleid"]:
        found = False
        for f in manifest_files:
            if sid in f.read_text(errors="ignore"):
                found = True
                break
        if found:
            in_manifest += 1
        else:
            not_in_manifest.append(sid)

    print("in manifests:", in_manifest)
    print("not in manifests:", len(not_in_manifest))
    if not_in_manifest:
        print("first missing:", ", ".join(not_in_manifest[:10]))
