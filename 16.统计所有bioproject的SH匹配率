import pandas as pd

meta = pd.read_csv("metadata/metadata_valid.csv", dtype=str)
mr = pd.read_csv("results/SH_mapping_rate_by_sample.tsv", sep="\t")

# 只保留需要的 mapping 信息
mr2 = mr[["sampleid", "group", "total_derep_reads", "matched_to_UNITE_SH", "mapping_rate"]].copy()
mr2["mapping_rate"] = pd.to_numeric(mr2["mapping_rate"], errors="coerce")
mr2["matched_to_UNITE_SH"] = pd.to_numeric(mr2["matched_to_UNITE_SH"], errors="coerce")
mr2["total_derep_reads"] = pd.to_numeric(mr2["total_derep_reads"], errors="coerce")

df = meta.merge(mr2, on="sampleid", how="left")

rows = []
for bp, g in df.groupby("BioProject", dropna=False):
    metadata_samples = len(g)
    with_mapping_rate = g["mapping_rate"].notna().sum()
    missing_mapping_rate = g["mapping_rate"].isna().sum()
    nonzero_samples = (g["mapping_rate"].fillna(0) > 0).sum()
    zero_samples = (g["mapping_rate"].fillna(-1) == 0).sum()
    ge02_samples = (g["mapping_rate"].fillna(0) >= 0.2).sum()
    total_matched = g["matched_to_UNITE_SH"].fillna(0).sum()
    total_derep = g["total_derep_reads"].fillna(0).sum()

    if nonzero_samples == 0:
        qc_status = "no_valid_SH_mapped_samples"
    elif ge02_samples == 0:
        qc_status = "very_low_SH_mapping"
    else:
        qc_status = "has_SH_mapped_samples"

    rows.append({
        "BioProject": bp,
        "metadata_samples": metadata_samples,
        "samples_with_mapping_rate": int(with_mapping_rate),
        "samples_missing_mapping_rate": int(missing_mapping_rate),
        "samples_mapping_rate_eq_0": int(zero_samples),
        "samples_mapping_rate_gt_0": int(nonzero_samples),
        "samples_mapping_rate_ge_0.2": int(ge02_samples),
        "mean_mapping_rate_among_available": g["mapping_rate"].mean(),
        "median_mapping_rate_among_available": g["mapping_rate"].median(),
        "min_mapping_rate_among_available": g["mapping_rate"].min(),
        "max_mapping_rate_among_available": g["mapping_rate"].max(),
        "total_derep_reads_available": int(total_derep),
        "total_SH_mapped_reads_available": int(total_matched),
        "overall_project_mapping_rate_available": total_matched / total_derep if total_derep > 0 else 0,
        "qc_status": qc_status,
    })

out = pd.DataFrame(rows).sort_values(
    ["samples_mapping_rate_gt_0", "overall_project_mapping_rate_available", "metadata_samples"],
    ascending=[True, True, False]
)

out.to_csv("results/SH_mapping_QC_by_BioProject_full_metadata.tsv", sep="\t", index=False)

print(out.head(30).to_string(index=False))
print()
print("Wrote results/SH_mapping_QC_by_BioProject_full_metadata.tsv")
