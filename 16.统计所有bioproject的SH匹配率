import pandas as pd

meta = pd.read_csv("metadata/metadata_valid.csv", dtype=str)

exclude_bioprojects = {
    "PRJNA695353",
    "PRJNA566442",
    "PRJNA745381",
    "PRJNA599105",
    "PRJNA511363",
    "PRJNA380769",
}

exclude_samples = {
    "SRR17629862",
}

removed = meta[
    meta["BioProject"].isin(exclude_bioprojects) |
    meta["sampleid"].isin(exclude_samples)
].copy()

filtered = meta[
    ~meta["BioProject"].isin(exclude_bioprojects) &
    ~meta["sampleid"].isin(exclude_samples)
].copy()

removed.to_csv("metadata/excluded_samples_no_valid_SH_mapping_or_pair_mismatch.csv", index=False)
filtered.to_csv("metadata/metadata_valid_SH_final.csv", index=False)

filtered_tsv = filtered.rename(columns={"sampleid": "sample-id"})
filtered_tsv.to_csv("metadata/metadata_valid_SH_final.tsv", sep="\t", index=False)

print("Original metadata samples:", len(meta))
print("Removed samples:", len(removed))
print("Remaining samples:", len(filtered))
print()
print("Removed by BioProject:")
print(removed["BioProject"].value_counts(dropna=False))
print()
print("Wrote:")
print("metadata/excluded_samples_no_valid_SH_mapping_or_pair_mismatch.csv")
print("metadata/metadata_valid_SH_final.csv")
print("metadata/metadata_valid_SH_final.tsv")
